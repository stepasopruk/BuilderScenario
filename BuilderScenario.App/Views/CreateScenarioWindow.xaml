<Window x:Class="BuilderScenario.App.Views.CreateScenarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
        Title="Создание сценария"
        Height="600"
        Width="500">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">

            <!-- Название сценария -->
            <TextBox Text="{Binding ScenarioName}"
                     Height="35"
                     Margin="0 0 0 15"/>

            <!-- Список групп -->
            <ItemsControl ItemsSource="{Binding Groups}"
                          dd:DragDrop.IsDragSource="True"
                          dd:DragDrop.IsDropTarget="True"
                          dd:DragDrop.UseDefaultDragAdorner="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="5"
                    Margin="0 0 0 15"
                    Padding="10">

                            <StackPanel>

                                <!-- Название группы -->
                                <TextBox Text="{Binding Name,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnNotifyDataErrors=True}"
                             Height="30"
                             Margin="0 0 0 10"/>

                                <!-- Шаги -->
                                <ItemsControl ItemsSource="{Binding Steps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="LightGray"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Margin="0 0 0 10"
                                        Padding="10">

                                                <StackPanel>

                                                    <!-- Название шага -->
                                                    <TextBox Text="{Binding Name,
                                                                    UpdateSourceTrigger=PropertyChanged,
                                                                    ValidatesOnNotifyDataErrors=True}"
                                                     Height="28"
                                                     Margin="0 0 0 10"/>

                                                    <Button Content="Удалить шаг"
                                                    Margin="0 5 0 0"
                                                    Command="{Binding DataContext.DeleteStepCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>

                                                    <!-- Действия -->
                                                    <ItemsControl ItemsSource="{Binding Actions}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBox Text="{Binding Name,
                                                                                    UpdateSourceTrigger=PropertyChanged,
                                                                                    ValidatesOnNotifyDataErrors=True}"
                                                                     Width="300"
                                                                     Margin="0 0 5 0"/>

                                                                    <Button Content="X"
                                                                    Width="30"
                                                                    Command="{Binding DataContext.DeleteActionCommand,
                                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <Button Content="Добавить действие"
                                                Height="30"
                                                Margin="0 5 0 0"
                                                Command="{Binding AddActionCommand}"/>

                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="Добавить шаг"
                            Height="35"
                            Margin="0 5 0 0"
                            Command="{Binding AddStepCommand}"/>

                                <Button Content="Удалить группу"
                                Margin="0 5 0 0"
                                Command="{Binding DataContext.DeleteGroupCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Кнопки -->
            <Button Content="Добавить группу действий"
                    Height="40"
                    Margin="0 10"
                    Command="{Binding AddGroupCommand}"/>

            <Button Content="Сохранить"
                    Height="40"
                    Command="{Binding SaveCommand}"/>

        </StackPanel>
    </ScrollViewer>

    <Window.Resources>
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="ToolTip"
                    Value="{Binding RelativeSource={RelativeSource Self},
                            Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

</Window>
