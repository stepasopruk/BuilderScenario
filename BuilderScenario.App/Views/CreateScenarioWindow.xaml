<Window x:Class="BuilderScenario.App.Views.CreateScenarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание сценария"
        Height="600"
        Width="500">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">

            <!-- Название сценария -->
            <TextBox Text="{Binding ScenarioName}"
                     Height="35"
                     Margin="0 0 0 15"/>

            <!-- Список групп -->
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="5"
                                Margin="0 0 0 10"
                                Padding="10">

                            <StackPanel>

                                <TextBox Text="{Binding Name}"
                                         Height="30"
                                         Margin="0 0 0 10"/>

                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Кнопки -->
            <Button Content="Добавить группу действий"
                    Height="40"
                    Margin="0 10"
                    Command="{Binding AddGroupCommand}"/>

            <Button Content="Сохранить"
                    Height="40"
                    Command="{Binding SaveCommand}"/>

        </StackPanel>
    </ScrollViewer>

</Window>
